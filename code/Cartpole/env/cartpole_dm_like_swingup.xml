<mujoco model="cartpole_dm_like_swingup">
  <compiler angle="radian"/>
  <option timestep="0.01" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.01"/>
    <geom conaffinity="0" contype="0" rgba="0.7 0.7 0.7 1"/>
  </default>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
  </visual>

  <worldbody>
    <light name="main_light" pos="0 -3 4" dir="0 0 -1"/>

    <geom
      name="rail"
      type="capsule"
      fromto="-2 0 0 2 0 0"
      size="0.02"
      rgba="0.2 0.2 0.2 1"/>

    <body name="cart" pos="0 0 0">
      <joint
        name="slider"
        type="slide"
        axis="1 0 0"
        range="-2 2"
        limited="true"
        damping="0.1"/>

      <geom
        name="cart_geom"
        type="box"
        size="0.12 0.08 0.06"
        mass="1.0"
        rgba="0.2 0.45 0.85 1"/>

      <body name="pole_root" pos="0 0 0">
        <joint
          name="hinge"
          type="hinge"
          axis="0 1 0"
          damping="0.02"/>

        <geom
          name="pole_geom"
          type="capsule"
          fromto="0 0 0 0 0 1"
          size="0.045"
          mass="0.1"
          rgba="0.85 0.3 0.3 1"/>
      </body>
    </body>

    <camera name="side" pos="0 -3.2 0.9" xyaxes="1 0 0 0 1 2.8"/>
  </worldbody>

  <actuator>
    <motor
      name="cart_motor"
      joint="slider"
      gear="100"
      ctrllimited="true"
      ctrlrange="-1 1"/>
  </actuator>
</mujoco>
