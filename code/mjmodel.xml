<mujoco model="two_link_drawer">
  <compiler angle="radian"/>

  <option timestep="0.01" gravity="0 0 0"/>

  <default>
    <joint damping="2"/>
    <geom rgba="0.7 0.7 0.7 1"/>
  </default>

  <worldbody>
    <geom name="floor" size="2 2 0.1" type="plane" rgba="0.95 0.95 0.95 1"/>
    <body name="base">
      <geom size="0.04 0.03" type="cylinder" rgba="0.2 0.2 0.2 1"/>
      <body name="link1">
        <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.2 2.2"/>
        <geom name="geom1" size="0.03 0.2" pos="0.25 0 0" quat="0.707107 0 -0.707107 0" type="capsule" contype="0" conaffinity="0" rgba="0.2 0.4 0.8 1"/>
        <body name="link2" pos="0.5 0 0">
          <joint name="joint2" pos="0 0 0" axis="0 0 1" range="0.1 2.6"/>
          <geom name="geom2" size="0.025 0.16" pos="0.2 0 0" quat="0.707107 0 -0.707107 0" type="capsule" contype="0" conaffinity="0" rgba="0.85 0.45 0.2 1"/>
          <site name="ee" pos="0.4 0 0" size="0.015" rgba="1 0 0 1"/>
          <body name="pen" pos="0.4 0 0">
            <geom name="pen_body" size="0.01 0.06" pos="0 0 -0.06" type="capsule" contype="0" conaffinity="0" rgba="0.1 0.1 0.1 1"/>
            <site name="pen_tip" pos="0 0 -0.12" size="0.01" rgba="0 0 0 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="act1" joint="joint1" ctrlrange="-2.2 2.2" biastype="affine" gainprm="180" biasprm="0 -180"/>
    <general name="act2" joint="joint2" ctrlrange="0.1 2.6" biastype="affine" gainprm="180" biasprm="0 -180"/>
  </actuator>
</mujoco>
