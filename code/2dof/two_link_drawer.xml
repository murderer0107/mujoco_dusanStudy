<mujoco model="two_link_drawer">
  <compiler angle="radian"/>
  <option timestep="0.01" gravity="0 0 0"/>

  <default>
    <joint damping="2"/>
    <geom rgba="0.7 0.7 0.7 1"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.95 0.95 0.95 1"/>

    <body name="base" pos="0 0 0">
      <geom type="cylinder" size="0.04 0.03" rgba="0.2 0.2 0.2 1"/>

      <body name="link1" pos="0 0 0">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-2.2 2.2"/>
        <geom name="geom1" type="capsule"
              fromto="0.05 0 0 0.60 0 0"
              size="0.03"
              rgba="0.2 0.4 0.8 1"
              contype="0" conaffinity="0"/>

        <body name="link2" pos="0.65 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="0.1 2.6"/>
          <geom name="geom2" type="capsule"
                fromto="0.04 0 0 0.46 0 0"
                size="0.025"
                rgba="0.85 0.45 0.2 1"
                contype="0" conaffinity="0"/>

          <site name="ee" pos="0.50 0 0" size="0.015" rgba="1 0 0 1"/>

          <body name="pen" pos="0.50 0 0">
            <geom name="pen_body" type="capsule"
                  fromto="0 0 0 0 0 -0.12"
                  size="0.01"
                  rgba="0.1 0.1 0.1 1"
                  contype="0" conaffinity="0"/>
            <site name="pen_tip" pos="0 0 -0.12" size="0.01" rgba="0 0 0 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="act1" joint="joint1" kp="180" ctrlrange="-2.2 2.2"/>
    <position name="act2" joint="joint2" kp="180" ctrlrange="0.1 2.6"/>
  </actuator>
</mujoco>